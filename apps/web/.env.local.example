# Copy to apps/web/.env.local

# The deployed FastAPI agent endpoint (code/api/app.py).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (email/password, Google OAuth, password reset).
# Leave BOTH blank to run the app in local "demo mode" (no real auth backend needed).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
