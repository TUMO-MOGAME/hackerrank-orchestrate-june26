# Copy to code/.env and fill in. NEVER commit .env. Secrets are read from env only.

# Which provider to use: anthropic | gemini | openai
CLAIMREVIEW_PROVIDER=gemini

# Model used for the submitted output.csv (best Macro-F1; only model that detects contradictions).
CLAIMREVIEW_MODEL=gemini-3-flash-preview

# Authenticity mode: provenance (C2PA, deterministic, zero-cost) | ensemble | vlm
CLAIMREVIEW_AUTH_MODE=provenance

# API keys — set the one for your chosen provider
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Operational tuning
CLAIMREVIEW_THROTTLE_MS=4500     # delay between model calls (respect free-tier RPM limits)
CLAIMREVIEW_MAX_RETRIES=3
CLAIMREVIEW_CACHE_ENABLED=true
